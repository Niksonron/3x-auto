# 3x-ui VPN Automation Configuration
# Copy this file to .env and fill in the values before installation.

# ============================================
# Server IP Addresses
# ============================================

# RU relay server public IP address
RU_RELAY_IP=""

# Foreign VPS public IP address (with 3x-ui)
FOREIGN_VPS_IP=""

# ============================================
# SSH Access Configuration
# ============================================

# SSH username for server access (must have sudo privileges)
SSH_USER=""

# SSH public key for authentication (contents of ~/.ssh/id_rsa.pub or similar)
# IMPORTANT: Password authentication will be disabled
SSH_PUBLIC_KEY=""

# ============================================
# VLESS Protocol Configuration
# ============================================

# VLESS listening port (e.g., 443, 8443, 2053)
VLESS_PORT="443"

# UUID for VLESS connections (generate with: cat /proc/sys/kernel/random/uuid)
UUID=""

# Transport protocol (must be TCP for Reality compatibility)
TRANSPORT="TCP"

# Security mode (must be reality)
SECURITY="reality"

# ============================================
# Reality Masking Parameters
# ============================================

# Server names for Reality handshake (comma-separated, e.g., "cloudflare.com,www.google.com")
SERVER_NAMES="cloudflare.com"

# Destination address for Reality traffic (real server to mimic)
DEST="cloudflare.com:443"

# Short IDs for Reality (comma-separated, 1-8 hex characters each)
# Leave empty to auto-generate
SHORT_IDS=""

# Reality private key (leave empty to auto-generate)
PRIVATE_KEY=""

# Reality public key (leave empty to auto-generate)
PUBLIC_KEY=""

# ============================================
# Optional Features
# ============================================

# Enable Cloudflare WARP outbound on foreign server (true/false)
ENABLE_WARP="false"

# Enable reverse proxy for 3x-ui panel (true/false)
# If true, panel will be accessible via DOMAIN with TLS
ENABLE_REVERSE_PROXY="false"

# Domain name for reverse proxy (required if ENABLE_REVERSE_PROXY=true)
# Must point to FOREIGN_VPS_IP
DOMAIN=""

# ============================================
# Advanced Settings
# ============================================

# SSH port (default: 22)
# SSH_PORT="22"

# 3x-ui panel port (default: 2053)
# PANEL_PORT="2053"

# 3x-ui admin username (default: admin)
# PANEL_USERNAME="admin"

# 3x-ui admin password (leave empty to auto-generate)
# PANEL_PASSWORD=""

# GeoIP database for RU routing (default: "geosite:category-ru")
# ROUTING_RU_GEOIP="geosite:category-ru"

# ============================================
# Generation Notes
# ============================================

# To generate a UUID:
#   cat /proc/sys/kernel/random/uuid
#   or: uuidgen

# To generate Reality keys (if leaving empty):
#   Script will auto-generate using xray reality command

# To get your SSH public key:
#   cat ~/.ssh/id_rsa.pub
#   or: cat ~/.ssh/id_ed25519.pub